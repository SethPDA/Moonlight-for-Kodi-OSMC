<?xml version="1.0" encoding="UTF-8"?>
<addon id="script.moonlight"
       name="Moonlight Game Streaming"
       version="1.1.0"
       provider-name="you">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
  </requires>
  <extension point="xbmc.python.script"
             library="default.py"/>
  <extension point="xbmc.addon.metadata">
    <summary>Launch Moonlight Game Streaming</summary>
    <description>Stops Kodi, launches Moonlight directly to your host, then restarts Kodi when done.</description>
    <platform>linux</platform>
    <icon>icon.png</icon>
    <fanart>fanart.jpg</fanart>
  </extension>
</addon>
